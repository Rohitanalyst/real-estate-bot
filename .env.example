# ============================================================
# AI MODEL (works out of the box - no key needed for demo!)
# The OpenAI-compatible API is pre-configured in the environment
# ============================================================
AI_MODEL=gemini-3-flash-preview

# ============================================================
# TELEGRAM BOT (get from @BotFather on Telegram)
# ============================================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ============================================================
# WHATSAPP BUSINESS API (get from Meta for Developers)
# ============================================================
WHATSAPP_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=my-verify-token

# ============================================================
# SERVER PORTS
# ============================================================
WHATSAPP_PORT=5000
ADMIN_PORT=8000

# ============================================================
# CUSTOMIZATION
# ============================================================
AGENT_NAME=Alex
COMPANY_NAME=Premium Properties
DB_PATH=leads.db
LOG_LEVEL=INFO
